{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schema.astrel.io/v1/astrel-config.schema.json",
  "title": "Astrel Remote Config",
  "description": "Published configuration schema for Astrel SDK consumption. Resolution order: Trigger → Lottery → Default",
  "type": "object",
  "required": ["schema_version", "published_at", "aspects"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for SDK compatibility checks"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this config was published"
    },
    "lottery": {
      "type": "object",
      "description": "Configuration for the deterministic lottery algorithm",
      "required": ["algorithm", "seed_format"],
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["sha256_mod10000"],
          "description": "SHA-256 hash of seed, first 4 bytes as big-endian uint32, mod 10000"
        },
        "seed_format": {
          "type": "string",
          "enum": ["{identifier}:{aspect_slug}"],
          "description": "Template for hash seed. identifier is the value the SDK consumer passes at flag-resolution time"
        }
      }
    },
    "triggers": {
      "type": "array",
      "description": "Ordered by priority (first active trigger with an override wins)",
      "items": {
        "$ref": "#/$defs/trigger"
      }
    },
    "aspects": {
      "type": "object",
      "description": "Aspect definitions keyed by slug",
      "additionalProperties": {
        "$ref": "#/$defs/aspect"
      }
    }
  },
  "$defs": {
    "config_value": {
      "description": "Any JSON-representable value",
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "object" },
        { "type": "array" }
      ]
    },
    "trigger": {
      "type": "object",
      "required": ["slug", "active", "aspects"],
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "active": {
          "type": "boolean"
        },
        "aspects": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/config_value"
          }
        }
      }
    },
    "aspect": {
      "type": "object",
      "required": ["type", "default"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["boolean", "string", "number", "json"],
          "description": "Value type for SDK type-safe accessors"
        },
        "default": {
          "$ref": "#/$defs/config_value",
          "description": "Base value when no other layer matches"
        },
        "lottery": {
          "$ref": "#/$defs/lottery_config"
        }
      }
    },
    "lottery_config": {
      "type": "object",
      "required": ["buckets"],
      "additionalProperties": false,
      "properties": {
        "buckets": {
          "type": "array",
          "minItems": 2,
          "description": "Weights must sum to 10000 (basis points)",
          "items": {
            "type": "object",
            "required": ["value", "weight"],
            "additionalProperties": false,
            "properties": {
              "value": {
                "$ref": "#/$defs/config_value"
              },
              "weight": {
                "type": "integer",
                "minimum": 1,
                "maximum": 10000
              }
            }
          }
        }
      }
    }
  }
}
